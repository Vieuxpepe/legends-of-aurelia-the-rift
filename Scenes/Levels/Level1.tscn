[sub_resource type="Resource" id="Resource_8a6bc"]
script = ExtResource("6_dm0ry")
speaker_name = "Kaelen"
portrait = ExtResource("7_lkv2p")
lines = Array[String](["Get the civilian behind those crates and keep your head down! These ruined walls are our only advantage.", "This alley creates a perfect chokepoint. I'll hold the vanguard right here and force them to fight me one at a time.", "{Avatar}, I need you covering my back. Your only job right now is to keep that villager breathing.", "If this barricade shatters, they'll swarm us. Brace yourselves—here they come!"])
metadata/_custom_type_script = "uid://ct2xqwun6g464"

