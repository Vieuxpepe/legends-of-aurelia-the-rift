[sub_resource type="Resource" id="Resource_8a6bc"]
script = ExtResource("6_noleb")
speaker_name = "Bartholomew"
portrait = ExtResource("8_d7ssd")
lines = Array[String](["This road is an abomination! My poor donkey is going to twist a hoof in this mud."])
metadata/_custom_type_script = "uid://ct2xqwun6g464"

[sub_resource type="Resource" id="Resource_yu4i8"]
script = ExtResource("6_noleb")
speaker_name = "Kaelen"
portrait = ExtResource("7_5dgei")
lines = Array[String](["Keep your voice down, merchant. The Emberwood is cursed soil. The dead don't stay buried here..."])
metadata/_custom_type_script = "uid://ct2xqwun6g464"

[sub_resource type="Resource" id="Resource_qqdt2"]
script = ExtResource("6_noleb")
lines = Array[String](["Commander, look ahead. Someone is blocking the path."])
metadata/_custom_type_script = "uid://ct2xqwun6g464"

[sub_resource type="Resource" id="Resource_hhqx0"]
script = ExtResource("6_noleb")
speaker_name = "Malakor"
portrait = ExtResource("9_qqdt2")
lines = Array[String](["The toll for this road is paid in blood. Surrender the supplies, and your deaths will be swift."])
metadata/_custom_type_script = "uid://ct2xqwun6g464"

[sub_resource type="Resource" id="Resource_lsi8b"]
script = ExtResource("6_noleb")
speaker_name = "Kaelen"
portrait = ExtResource("7_5dgei")
lines = Array[String](["Vanguard cultists. They're trying to cut off our supply line to the fortress! {Avatar}, form a perimeter around the cart. We push through them!"])
metadata/_custom_type_script = "uid://ct2xqwun6g464"

[sub_resource type="Resource" id="Resource_0tovn"]
script = ExtResource("6_noleb")
speaker_name = "Bartholomew"
portrait = ExtResource("8_d7ssd")
lines = Array[String](["We made it, lads! I can see the fields!", "My glorious donkey lives to haul another day. A truly profitable outcome."])
metadata/_custom_type_script = "uid://ct2xqwun6g464"

[sub_resource type="Resource" id="Resource_08kon"]
script = ExtResource("6_noleb")
speaker_name = "Kaelen"
portrait = ExtResource("7_5dgei")
lines = Array[String](["Don't celebrate yet. Keep the cart moving until we are fully clear of the tree line.", "I want this cursed forest a mile behind us before anyone rests."])
metadata/_custom_type_script = "uid://ct2xqwun6g464"

