		"req_level": 5,
		"once_per_visit": true,
		"requires_units_present": ["Pell Rowan"],
		"script": [
			{"speaker": "Mira Ashdown", "text": "Your hand signals are too large. You're not hailing a ship."},
			{"speaker": "Pell Rowan", "text": "I wanted them visible. So nobody mistakes me for… for nothing."},
			{"speaker": "Mira Ashdown", "text": "Visibility isn't confidence. It's motion. Motion pulls eyes off the threat."},
			{"speaker": "Pell Rowan", "text": "Smaller, then. Like I'm ashamed to exist."},
			{"speaker": "Mira Ashdown", "text": "Like you're precise. Shame is noisy. Quiet is how you stay alive long enough to become what you admire."},
		],
		"effects_on_complete": {"add_avatar_relationship": 1},
	},
	{
		"id": "dc_camp_avatar_hest_1",
		"primary_unit": "Hest \"Sparks\"",
		"participants": ["Hest \"Sparks\"", "Commander"],
		"conversation_type": "support",
		"priority": 16,
		"req_level": 4,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Hest \"Sparks\"", "text": "I can rig this from scrap and spite—it'll work, it'll sing, it'll scare the pigeons. That's the version I know in my bones."},
			{"speaker": "Commander", "text": "I need the version that doesn't gamble the line."},
			{"speaker": "Hest \"Sparks\"", "text": "Gambling is how you stay interesting enough not to be replaced. Useful gets you fed. Interesting gets you remembered."},
			{"speaker": "Commander", "text": "You're already remembered. I'm asking what you're proving."},
			{"speaker": "Hest \"Sparks\"", "text": "Fine. Ugly truth: slow work feels like standing still in someone's kindness—and standing still is how you learn the exit clause. So which do you want from me—prove I'm worth keeping with a flash… or prove I'm worth keeping by being too dull to discard?"},
		],
		"choices": [
			{
				"text": "Dull. Prove it with the work nobody applauds.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "I don't hire you for theater. I need you here tomorrow, fingers intact, ego bruised if it has to be."},
					{"speaker": "Hest \"Sparks\"", "text": "...That's a weird kind of loyalty. I'll take it."},
					{"speaker": "Hest \"Sparks\"", "text": "I'll build it slow—jury-rigged patience, borrowed clamps, the whole unglamorous sermon."},
					{"speaker": "Commander", "text": "Good."},
					{"speaker": "Hest \"Sparks\"", "text": "If you meant it—if dull still counts as kept—say it again sometime when I'm not joking. I hear those better."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "Flash. I'll own the risk—you're not disposable.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "We don't have hours. Push it—I won't blame you for being brilliant."},
					{"speaker": "Hest \"Sparks\"", "text": "Careful. That's how people talk right before they learn math."},
					{"speaker": "Hest \"Sparks\"", "text": "I'll tighten what I can and lie to the housing like it deserves poetry. If it bites us, it's the story I know how to carry."},
					{"speaker": "Commander", "text": "If it bites, it's on me—not on you."},
					{"speaker": "Hest \"Sparks\"", "text": "...Yeah. All right. Don't make me regret trusting a promise that sounds like bread."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_hest_1"},
	},
	{
		"id": "dc_camp_avatar_darian_1",
		"primary_unit": "Darian",
		"participants": ["Darian", "Commander"],
		"conversation_type": "support",
		"priority": 16,
		"req_level": 3,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Darian", "text": "I can make this camp feel like a ballroom with worse wine—same trick I learned before I knew what the rooms were buying."},
			{"speaker": "Commander", "text": "Buying?"},
			{"speaker": "Darian", "text": "Attention. Allegiance. The illusion that nothing is starving as long as the sentence sounds pretty."},
			{"speaker": "Commander", "text": "You're good at the sentence."},
			{"speaker": "Darian", "text": "I was trained before I was trusted. So tell me which appetite you want fed tonight—morale polished enough to shine… or the version where I stop arranging the room and let you see the rot I'm still angry at?"},
		],
		"choices": [
			{
				"text": "The rot. No polish.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "I've seen hunger dressed in silk. I don't need you to dress this."},
					{"speaker": "Darian", "text": "...Gods. Straight as a peasant blade."},
					{"speaker": "Darian", "text": "Then hear it plain: I hate how easily my old world starved people while praising their posture. I joke because anger without timing is just another noble tantrum."},
					{"speaker": "Commander", "text": "Anger with timing is useful."},
					{"speaker": "Darian", "text": "Then I'll spend mine on keeping bellies full and mouths honest—even when honesty costs me the tune."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "Polish tonight. Anger later.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "Give them the evening. We'll speak plain after."},
					{"speaker": "Darian", "text": "Dangerous kindness. You're offering me the mask and the door."},
					{"speaker": "Darian", "text": "I'll play the charming fool publicly—it's what I'm good at. Privately… knock twice if you meant it. I don't trust single knocks anymore."},
					{"speaker": "Commander", "text": "I'll knock twice."},
					{"speaker": "Darian", "text": "Good. Even disgraced nobles need one room where performance isn't payment."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_darian_1"},
	},
	{
		"id": "dc_camp_avatar_yselle_1",
		"primary_unit": "Yselle Maris",
		"participants": ["Yselle Maris", "Commander"],
		"conversation_type": "support",
		"priority": 16,
		"req_level": 4,
		"once_ever": true,
		"script": [
			{"speaker": "Yselle Maris", "text": "You shrink when you think no one with a title is watching. That is backwards. The titled are the least dangerous audience."},
			{"speaker": "Commander", "text": "I'm used to being looked through."},
			{"speaker": "Yselle Maris", "text": "I know the taste of being seen before being known. It teaches you posture—or it teaches you to disappear on purpose."},
			{"speaker": "Commander", "text": "You want posture."},
			{"speaker": "Yselle Maris", "text": "I want you to understand what posture costs me—and why I still pay it. Grace is not vanity here. It is how a body keeps panic from infecting a tent line."},
			{"speaker": "Commander", "text": "That sounds like work."},
			{"speaker": "Yselle Maris", "text": "It is labor—the kind people dismiss as ornament until they need one calm face to walk past. Be that face, not for admirers… for the ones who cannot afford another collapse tonight."},
		],
		"effects_on_complete": {"add_avatar_relationship": 2, "advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_yselle_1"},
	},
	{
		"id": "dc_camp_avatar_yselle_2",
		"primary_unit": "Yselle Maris",
		"participants": ["Yselle Maris", "Commander"],
		"conversation_type": "support",
		"priority": 16,
		"req_level": 6,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Yselle Maris", "text": "They want supper 'plain' tonight—no cloth on the board, cups crooked on purpose, as if ugliness proves seriousness."},
			{"speaker": "Commander", "text": "Rations are tight."},
			{"speaker": "Yselle Maris", "text": "Rations are real. So is the hour before someone breaks. I've sold calm with linen before I could sell it with truth—don't mistake the craft for frivolity."},
			{"speaker": "Commander", "text": "What do you need from me?"},
			{"speaker": "Yselle Maris", "text": "A ruling—and permission without pity. Do I keep the face polished where the line can borrow it… or may I set the performance down with you and let exhaustion show? Shield for everyone… or gift for one?"},
		],
		"choices": [
			{
				"text": "The shield. Give them what they can lean on.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "Arrange the table. If anyone calls it vanity, send them to me."},
					{"speaker": "Yselle Maris", "text": "They'll call it vanity anyway. I'm used to being misread by people who never paid for visibility."},
					{"speaker": "Yselle Maris", "text": "I'll make the evening honest in its own language—order without theater, warmth without spectacle."},
					{"speaker": "Commander", "text": "That's still work."},
					{"speaker": "Yselle Maris", "text": "Work is what keeps me from being reduced to a portrait. When you defend it, you defend more than cups."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "With me—no polish. I want the tired version.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "The camp can eat crooked cups. With me, sit like you're not on display."},
					{"speaker": "Yselle Maris", "text": "...Dangerous. Kind. I don't often get asked for the person behind the arrangement."},
					{"speaker": "Yselle Maris", "text": "Then I'll bring bread and silence—not a performance, not a lesson. If my hands shake, you'll know it's real."},
					{"speaker": "Commander", "text": "That's enough."},
					{"speaker": "Yselle Maris", "text": "Is it? Good. Being known costs more than being seen. I'll pay it tonight—and pick the armor back up before dawn without pretending it weighs nothing."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_yselle_2"},
	},
	{
		"id": "dc_camp_avatar_veska_1",
		"primary_unit": "Veska Moor",
		"participants": ["Veska Moor", "Commander"],
		"conversation_type": "support",
		"priority": 16,
		"req_level": 5,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Veska Moor", "text": "I've been the thing they leaned on while they called it 'the line.' They forget there's meat behind a shield until it hurts."},
			{"speaker": "Commander", "text": "I won't forget."},
			{"speaker": "Veska Moor", "text": "Good. Forgetting is how officers learn pretty language. Pretty language doesn't stop a ram."},
			{"speaker": "Commander", "text": "They still need a why."},
			{"speaker": "Veska Moor", "text": "Then choose, Commander—do you want a why that sounds heroic on a banner… or a why that fits in a breath and keeps their feet planted when the banner's ash?"},
		],
		"choices": [
			{
				"text": "The breath. No banner poetry.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "Tell them: hold, count, breathe, trust the shoulder beside you. That's the sermon."},
					{"speaker": "Veska Moor", "text": "Ugly. Honest. Mine."},
					{"speaker": "Veska Moor", "text": "I'll drill until their bodies know the wall better than their mouths know slogans."},
					{"speaker": "Commander", "text": "Good."},
					{"speaker": "Veska Moor", "text": "Heroics are for people whose mistakes get cushioned. We're not those people."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "Banner first—then your breath underneath.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "Give them a word to carry. Then make the work true enough to deserve it."},
					{"speaker": "Veska Moor", "text": "Dangerous order. Fine."},
					{"speaker": "Veska Moor", "text": "I'll keep the shield-wall honest while you hand them something to believe. If the belief lies, it will kill them—not me."},
					{"speaker": "Commander", "text": "It won't lie."},
					{"speaker": "Veska Moor", "text": "See that it doesn't. I've cleaned up after speeches before."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_veska_1"},
	},
	{
		"id": "dc_camp_avatar_veska_2",
		"primary_unit": "Veska Moor",
		"participants": ["Veska Moor", "Commander"],
		"conversation_type": "support",
		"priority": 16,
		"req_level": 7,
		"required_arc_flags": ["dc_camp_avatar_veska_1"],
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Veska Moor", "text": "I spent the morning scrubbing another shield—knuckles split because a sergeant liked how 'unyielding' sounded before the charge."},
			{"speaker": "Commander", "text": "You want his ears, or mine?"},
			{"speaker": "Veska Moor", "text": "Yours. You're the one who signs the words they steal. Meat pays for adjectives; I'm tired of collecting the receipt in bruises."},
			{"speaker": "Commander", "text": "What do you need the next time I have to lift the line?"},
			{"speaker": "Veska Moor", "text": "Choose, Commander—do you want me to speak the wall's real tally out loud where rookies can hear it… or one clean word that dies in the breath I give it for free?"},
		],
		"choices": [
			{
				"text": "The tally. Let them hear the cost.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "No romance. Shoulders, wrists, breath—say it plain before anyone salutes a slogan."},
					{"speaker": "Veska Moor", "text": "Ugly. Useful. That's how you train bodies to trust the shield instead of the story."},
					{"speaker": "Veska Moor", "text": "I'll drill it until their feet believe me more than their mouths do."},
					{"speaker": "Commander", "text": "Good."},
					{"speaker": "Veska Moor", "text": "If a speech still kills someone, I want the blood on the language—not on the line pretending it didn't know."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "One word—then you decide how long it lives.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "Give them a single honest anchor. If it survives past your breath, that's on me—not on your throat."},
					{"speaker": "Veska Moor", "text": "Dangerous kindness. Fine—I'll spend the word like coin and let it go when the lungs do."},
					{"speaker": "Veska Moor", "text": "But if it gets carved into a banner while I'm still rinsing rust out of someone's hair, we're having this talk again with less patience."},
					{"speaker": "Commander", "text": "Fair."},
					{"speaker": "Veska Moor", "text": "Fair is rare. I'll take it when I can get it—and hold the shield honest while you learn which promises cost knees."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_veska_2"},
	},
	{
		"id": "dc_camp_avatar_corvin_1",
		"primary_unit": "Corvin Ash",
		"participants": ["Corvin Ash", "Commander"],
		"conversation_type": "support",
		"priority": 16,
		"req_level": 6,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Corvin Ash", "text": "I grew up where sealed ink meant safety—until I learned what gets sealed."},
			{"speaker": "Commander", "text": "What do you want to put in ours?"},
			{"speaker": "Corvin Ash", "text": "Not comfort. Comfort is a lid. Lids breed mold."},
			{"speaker": "Commander", "text": "People need sleep."},
			{"speaker": "Corvin Ash", "text": "Then choose: do you want me to curate what they remember—myth with soft edges—or keep a record calm enough to name the horror without flinching?"},
		],
		"choices": [
			{
				"text": "Name it. No soft edges in the record.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "If we're lying to ourselves, I want it visible."},
					{"speaker": "Corvin Ash", "text": "Good. Visibility is the only disinfectant I trust."},
					{"speaker": "Corvin Ash", "text": "I'll write what breaks sermons. If that makes me cold, ask whether warmth ever kept a curse from spreading."},
					{"speaker": "Commander", "text": "You're not cold. You're exact."},
					{"speaker": "Corvin Ash", "text": "Exact is the kindest thing I can offer. Don't ask me to mimic reassurance—I never learned it without lying."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "Curate for the fire. Keep the cold copy for us.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "Give the camp a story that holds them up. Keep the truth where it can't panic the sick."},
					{"speaker": "Corvin Ash", "text": "Two books. One warm, one honest. I hate it—but I understand it."},
					{"speaker": "Corvin Ash", "text": "I'll polish the public line until it stops cutting. The private one stays unvarnished. If the gap widens, that's on leadership—not on language."},
					{"speaker": "Commander", "text": "I'll own the gap."},
					{"speaker": "Corvin Ash", "text": "See that you do. I've watched institutions hide behind good phrasing. I'd rather not become one."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_corvin_1"},
	},
	{
		"id": "dc_camp_avatar_corvin_2",
		"primary_unit": "Corvin Ash",
		"participants": ["Corvin Ash", "Commander"],
		"conversation_type": "support",
		"priority": 16,
		"req_level": 8,
		"required_arc_flags": ["dc_camp_avatar_corvin_1"],
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Corvin Ash", "text": "Someone copied a cold line into the warm copy last week—trimmed the casualty count so the sentence would 'carry better.'"},
			{"speaker": "Commander", "text": "You want permission to be cruel."},
			{"speaker": "Corvin Ash", "text": "I want permission to stay exact. Softening spreads—one polite omission becomes precedent. Next week it eats a name."},
			{"speaker": "Commander", "text": "What's the price if we refuse to soften?"},
			{"speaker": "Corvin Ash", "text": "Every honest witness inherits a little contamination—touch the truth and you carry it. I'd rather that debt than a future that thinks it was clean."},
		],
		"choices": [
			{
				"text": "Keep the record flat. I'll carry the debt with you.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "No trimmed counts. If the camp flinches, that's leadership's problem—not the ink's."},
					{"speaker": "Corvin Ash", "text": "Good. Flat ink is the only ledger I trust not to rot quietly."},
					{"speaker": "Corvin Ash", "text": "I'll mark who touched what—memory leaves fingerprints. If someone tries to launder horror into heroics again, the stain will have a name."},
					{"speaker": "Commander", "text": "Do it."},
					{"speaker": "Corvin Ash", "text": "Then we agree: truth costs everyone who holds it. I'd rather pay that than pay for a pretty lie that multiplies in the dark."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "One mercy trim—for the sick tents only. Nothing else.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "If panic will kill the wounded, give them one sentence they can sleep on. The cold copy stays whole."},
					{"speaker": "Corvin Ash", "text": "A narrow gate. I'll hate myself for every millimeter I grant—and log it anyway."},
					{"speaker": "Corvin Ash", "text": "If the gap widens, you'll hear it in my voice before the archive does. Contamination doesn't stay polite."},
					{"speaker": "Commander", "text": "I'll watch the gap."},
					{"speaker": "Corvin Ash", "text": "See that you do. Two books already tempt people to cheat. I'd rather cheat once with eyes open than pretend the mold isn't spreading."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_corvin_2"},
	},
	{
		"id": "dc_camp_avatar_meris_1",
		"primary_unit": "Sister Meris",
		"participants": ["Sister Meris", "Commander"],
		"conversation_type": "support",
		"priority": 16,
		"req_level": 5,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Sister Meris", "text": "I was taught that certainty is mercy—sort the soul, file the fault, close the case."},
			{"speaker": "Commander", "text": "And now?"},
			{"speaker": "Sister Meris", "text": "Now I know what it costs to treat a person as a case. I still hear the old reflex: name the sin, restore order."},
			{"speaker": "Commander", "text": "What's the new reflex fighting it?"},
			{"speaker": "Sister Meris", "text": "Need. Messy, undignified need. Tell me—when I reach for forgiveness fast, am I offering grace… or am I still trying to be the kind of servant who never leaves a file open?"},
		],
		"choices": [
			{
				"text": "Leave the file open. Start with need.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "Bread before verdict. Sleep before speech. That's not softness—it's how you stop mistaking exhaustion for wickedness."},
					{"speaker": "Sister Meris", "text": "...That sentence would have angered my old teachers."},
					{"speaker": "Sister Meris", "text": "Good. Let them be angry in memory. I'll be useful in the present."},
					{"speaker": "Commander", "text": "You don't need my permission to be merciful."},
					{"speaker": "Sister Meris", "text": "I need the courage to disobey the part of me that thought cruelty was clarity."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "Keep truth first. Mercy has to mean something.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "If we erase fault to feel clean, we train people to expect cheap grace."},
					{"speaker": "Sister Meris", "text": "Harsh. Close to what I used to call discipline."},
					{"speaker": "Sister Meris", "text": "I'll speak plainly, then—and watch myself for the old pleasure of being right."},
					{"speaker": "Commander", "text": "Alden will tell you if you cross into punishment."},
					{"speaker": "Sister Meris", "text": "I'll ask him. The Church taught me to fear doubt; this army is teaching me to fear certainty more."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_meris_1"},
	},
	{
		"id": "dc_camp_avatar_maela_1",
		"primary_unit": "Maela Thorn",
		"participants": ["Maela Thorn", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 16,
		"req_level": 5,
		"once_ever": true,
		"script": [
			{"speaker": "Maela Thorn", "text": "When you're angry, you lengthen your stride like you're trying to outrun someone who isn't there."},
			{"speaker": "Commander", "text": "Who isn't there?"},
			{"speaker": "Maela Thorn", "text": "Every voice that ever called you slow, small, wrong. I know the sound. It makes you want height."},
			{"speaker": "Commander", "text": "I'll shorten up."},
			{"speaker": "Maela Thorn", "text": "Don't perform shortening. Fix the habit. Anger eats air—you need air for orders."},
			{"speaker": "Commander", "text": "What do you want from me in the ring?"},
			{"speaker": "Maela Thorn", "text": "One day of fundamentals so dull the rookies yawn. Dull is how you prove you're not still arguing with old dismissals—because skill doesn't need an audience."},
		],
		"effects_on_complete": {"add_avatar_relationship": 2, "advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_maela_1"},
	},
	{
		"id": "dc_camp_avatar_maela_2",
		"primary_unit": "Maela Thorn",
		"participants": ["Maela Thorn", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 16,
		"req_level": 7,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Maela Thorn", "text": "Rain turned the ring to porridge. Half the line wants a show; half needs ankles in the morning."},
			{"speaker": "Commander", "text": "Recommend."},
			{"speaker": "Maela Thorn", "text": "Honest footwork—slow until hips stop performing for each other. Or one clean flourish they can whistle about while their pride picks the next fight."},
			{"speaker": "Commander", "text": "You're asking what I'm trying to prove."},
			{"speaker": "Maela Thorn", "text": "I'm asking whose voice you hear when you hesitate—mine, theirs… or every old bastard who called you too small to matter. Restraint in the mud… or speed that buys applause and maybe a limp?"},
		],
		"choices": [
			{
				"text": "Restraint. Boring footing until it holds.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "No spectacle. I'd rather they hate the drill than love the fall."},
					{"speaker": "Maela Thorn", "text": "Good. Applause is a drug for people who confuse being watched with being safe."},
					{"speaker": "Maela Thorn", "text": "I'll run them through stance until the mud makes liars of anyone posturing."},
					{"speaker": "Commander", "text": "Push them."},
					{"speaker": "Maela Thorn", "text": "I'll push the work—not their egos. Competence is the only proof I still chase… because it's the only one that ever shut the old voices up for whole minutes."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "One flourish—then you grind them on balance.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "Give them a spark—once—then punish sloppy footing until they respect the ground."},
					{"speaker": "Maela Thorn", "text": "Hah. Dangerous order. Fine—I'll spend my reputation on the flash and yours on the cleanup."},
					{"speaker": "Maela Thorn", "text": "They'll remember the move. I'll make sure they remember the ache that teaches where weight belongs."},
					{"speaker": "Commander", "text": "Fair trade."},
					{"speaker": "Maela Thorn", "text": "Fair is rare. Don't get addicted to the cheer—it's the same hunger that used to make me leap before I was ready, just to prove I existed."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_maela_2"},
	},
	{
		"id": "dc_camp_avatar_tariq_2",
		"primary_unit": "Tariq",
		"participants": ["Tariq", "Commander"],
		"conversation_type": "support",
		"priority": 15,
		"req_level": 6,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Tariq", "text": "I was trained where truth had a patron. The patron decided what 'neutral' meant."},
			{"speaker": "Commander", "text": "And the scouts' report?"},
			{"speaker": "Tariq", "text": "It's already being sold—fear as entertainment, rumor as currency. Someone will profit whether we speak or stay silent."},
			{"speaker": "Commander", "text": "What do you recommend?"},
			{"speaker": "Tariq", "text": "Choose what you're buying: a translation that keeps hands steady… or a translation that refuses to let horror be priced as gossip. Which market do you want me to shut down first?"},
		],
		"choices": [
			{
				"text": "Steady hands. Starve the gossip market.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "I won't fund panic. Give them facts without theater."},
					{"speaker": "Tariq", "text": "Then I'll write like a miser—every word earned, none borrowed for flair."},
					{"speaker": "Tariq", "text": "If patrons taught me anything, it's how to refuse a bad sale."},
					{"speaker": "Commander", "text": "Good."},
					{"speaker": "Tariq", "text": "If they call it cold—remind them warmth is how merchants wrap rot."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "Make horror costly to ignore.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "I don't want this smoothed into something easy to repeat by the fire."},
					{"speaker": "Tariq", "text": "Then you'll get language with edges. People will flinch—and some will call you cruel for being clear."},
					{"speaker": "Tariq", "text": "I'll do it anyway. I've paid for clarity before; I can pay again."},
					{"speaker": "Commander", "text": "I'll take the blame."},
					{"speaker": "Tariq", "text": "See that you do. Sharp truth without protection is just another way to abandon the speaker."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_tariq_2"},
	},
	{
		"id": "dc_camp_avatar_sabine_2",
		"primary_unit": "Sabine Varr",
		"participants": ["Sabine Varr", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 15,
		"req_level": 7,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Sabine Varr", "text": "I've watched good people die because someone felt 'off' and nobody had language for it until too late."},
			{"speaker": "Commander", "text": "You're saying our pattern is a liability."},
			{"speaker": "Sabine Varr", "text": "I'm saying habit is a ledger. It records where we stop looking."},
			{"speaker": "Commander", "text": "Changing the ledger scares the line."},
			{"speaker": "Sabine Varr", "text": "Then choose: keep a comforting rhythm because it feels loyal… or bend the system now—logistics, handoffs, counts—so loyalty survives contact with reality?"},
		],
		"choices": [
			{
				"text": "Bend it. Rewrite rotations and handoffs.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "I'll sell it as care for the living, not doubt of the dead."},
					{"speaker": "Sabine Varr", "text": "Good. Grief is private. Procedure is how we protect each other anyway."},
					{"speaker": "Sabine Varr", "text": "I'll draft variants until the wall stops telling the enemy what time we blink."},
					{"speaker": "Commander", "text": "Coordinate with Garrick."},
					{"speaker": "Sabine Varr", "text": "Already on it. If he complains, I'll translate his pride into timetables."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "Keep the skeleton. Hide jolts inside it.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "Stability matters. Smuggle the unpredictability—don't break their footing."},
					{"speaker": "Sabine Varr", "text": "Fair. Then spot checks, snap drills, random counts—small fractures, same spine."},
					{"speaker": "Sabine Varr", "text": "Care that doesn't survive logistics isn't care. It's mood."},
					{"speaker": "Commander", "text": "No mood. Just teeth."},
					{"speaker": "Sabine Varr", "text": "Agreed. I'll grieve after the perimeter holds."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_sabine_2"},
	},
	{
		"id": "dc_camp_avatar_inez_2",
		"primary_unit": "Inez",
		"participants": ["Inez", "Commander"],
		"conversation_type": "support",
		"priority": 15,
		"req_level": 7,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Inez", "text": "Armies call it 'passing through.' Forests call it intrusion. I listen for the second word longer."},
			{"speaker": "Commander", "text": "Teach me the difference."},
			{"speaker": "Inez", "text": "Intrusion leaves more than tracks. It leaves appetite. Protection leaves less."},
			{"speaker": "Commander", "text": "What do you want me to practice?"},
			{"speaker": "Inez", "text": "Ten heartbeats of stillness while I adjust you—like correcting a bow that thinks it's a shout—or you keep your distance and only take the idea. Which do you trust: my hands… or your rank?"},
		],
		"choices": [
			{
				"text": "Your hands. I'll be still.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "Rank doesn't know how to listen to bark. Teach."},
					{"speaker": "Inez", "text": "Good. Breathe. Shoulders down. Stop claiming ground you don't need."},
					{"speaker": "Inez", "text": "Again. The soil remembers arrogance. So do I."},
					{"speaker": "Commander", "text": "...I hear it."},
					{"speaker": "Inez", "text": "Then you're learning. Trust is letting someone change your shape without taking your name."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "The idea only. Keep your distance.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "I'll take the lesson without the touch."},
					{"speaker": "Inez", "text": "Outsiders always say that first."},
					{"speaker": "Inez", "text": "I'll point where your weight lies. But ideas don't stop a patrol that already decided you own too much."},
					{"speaker": "Commander", "text": "Understood."},
					{"speaker": "Inez", "text": "When you trust land more than title, come back. I'll still be listening."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_inez_2"},
	},
	{
		"id": "dc_camp_avatar_nyx_callback",
		"primary_unit": "Nyx",
		"participants": ["Nyx", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 8,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_nyx_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Nyx", "text": "East relief's slate still has my name on it—visible, like you promised. I keep checking the ink like it'll vanish if I blink."},
			{"speaker": "Commander", "text": "It won't. That's the point of writing it."},
			{"speaker": "Nyx", "text": "Old me would've called that ownership. New me is… testing whether accountable feels like rope or like a roof."},
			{"speaker": "Commander", "text": "Which is it lately?"},
			{"speaker": "Nyx", "text": "Roof more often. Don't get smug—I'm still allergic to being grateful out loud."},
			{"speaker": "Commander", "text": "Then stay dry. That's enough."},
			{"speaker": "Nyx", "text": "You wanted a person, not a knife. Fine—person says this: being counted toward the wall beats being counted toward the door. I remember which one you chose when the gap opened."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_nyx_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_branik_callback",
		"primary_unit": "Branik",
		"participants": ["Branik", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 8,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_branik_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Branik", "text": "I told you I'd stopped being subtle about caring. Turns out the camp heard it anyway—someone asked if I'd 'adopted' you off the books."},
			{"speaker": "Commander", "text": "What did you say?"},
			{"speaker": "Branik", "text": "That stew isn't a metaphor. If I push bread at you, it's because empty hands make cruel orders—not because I'm collecting gratitude."},
			{"speaker": "Commander", "text": "I didn't think you were."},
			{"speaker": "Branik", "text": "Good. The larder taught me honesty isn't cruelty; it's the kind of care that doesn't waste your next week. I'm holding to that even when you try to be stone."},
			{"speaker": "Commander", "text": "Stone gets hungry too."},
			{"speaker": "Branik", "text": "Then sit. Eat. If your hands shake, I won't treat it like theater—I'll treat it like data, same as before. That's not logistics disguised anymore. That's me refusing to let you go hollow on my watch."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_branik_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_sorrel_callback",
		"primary_unit": "Sorrel",
		"participants": ["Sorrel", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 9,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_sorrel_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Sorrel", "text": "That margin fragment is still chewing at me—raw ink, shaped ink, both honest in different ways. You forced me to stop laundering fear into something pretty."},
			{"speaker": "Commander", "text": "You forced me to carry the ugly numbers."},
			{"speaker": "Sorrel", "text": "Good trade. Silence would've cost more on the road than flinch ever cost in a tent."},
			{"speaker": "Commander", "text": "So what are you doing differently now?"},
			{"speaker": "Sorrel", "text": "I bring the interpretation early—before rumor does it for me. Not to soften rigor. To keep rigor from becoming a religion nobody can argue with."},
			{"speaker": "Commander", "text": "That sounds like trust."},
			{"speaker": "Sorrel", "text": "It sounds like shared responsibility—which I dislike on principle and practice anyway because the alternative is anecdotes dressed as plans."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_sorrel_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_tamsin_callback",
		"primary_unit": "Tamsin Reed",
		"participants": ["Tamsin Reed", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 8,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_tamsin_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Tamsin Reed", "text": "Remember when I said rest is a fantasy I visit after the list stops screaming? I'm trying an uglier version: naming the ceiling before I hit it."},
			{"speaker": "Commander", "text": "What's the ceiling tonight?"},
			{"speaker": "Tamsin Reed", "text": "Four hands pretending to be six. If another 'minor' injury walks in, I need someone else's heroics—not mine performed while I'm swaying."},
			{"speaker": "Commander", "text": "I'll pull a second pair of hands."},
			{"speaker": "Tamsin Reed", "text": "Good. That's the kind of help I used to hide under jokes about thin pots."},
			{"speaker": "Commander", "text": "No shame in asking."},
			{"speaker": "Tamsin Reed", "text": "There's shame in collapsing to prove I'm indispensable—triage already taught me heroics are cheaper when they're honest about who pays. I'm paying in sleep now, not in silence."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_tamsin_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_celia_callback",
		"primary_unit": "Celia",
		"participants": ["Celia", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 7,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_celia_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Celia", "text": "Same pass drill came back—third count—but I didn't chase pain for proof this time. I chased boring until my shoulders stopped auditioning."},
			{"speaker": "Commander", "text": "That's the version we practiced."},
			{"speaker": "Celia", "text": "Small right, not loud penance. It still feels like cheating—like if nobody sees me suffer, maybe I'm not serious."},
			{"speaker": "Commander", "text": "Serious is the rep, not the bruise."},
			{"speaker": "Celia", "text": "I'm learning. Kaelen's praise stopped sounding like a loan I have to bleed interest on."},
			{"speaker": "Commander", "text": "Good."},
			{"speaker": "Celia", "text": "If I slip into performance again, say 'boring'—same word as before. It's a better anchor than shame. I'm not borrowing shame to prove I'm committed; I'm keeping the step."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_celia_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_garrick_callback",
		"primary_unit": "Garrick Vale",
		"participants": ["Garrick Vale", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 25,
		"req_level": 9,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_garrick_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Garrick Vale", "text": "Sections adapted last night without you hovering—mud disagreed with the manual, and sergeants bent time instead of throats. I wrote it plain in the notes."},
			{"speaker": "Commander", "text": "Any blowback?"},
			{"speaker": "Garrick Vale", "text": "Griping—healthy kind. Nobody died proving they could obey a clock."},
			{"speaker": "Commander", "text": "You sound satisfied."},
			{"speaker": "Garrick Vale", "text": "I'm satisfied the wall learned judgment isn't a solo sport. Institutions survive on memory; armies survive on what people do when ink's wet—I meant that when I said it."},
			{"speaker": "Commander", "text": "Keep sending the notes."},
			{"speaker": "Garrick Vale", "text": "You'll get them without theater. Trust isn't me supervising every choice anymore—it's me backing calls when the ground argues. That's distributed, not decorative."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_garrick_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_kaelen_callback",
		"primary_unit": "Kaelen",
		"participants": ["Kaelen", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 9,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_kaelen_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Kaelen", "text": "Here's what I hate admitting after Greyspire: your stubborn refusal to die in Emberwood wasn't vanity—it was the same reflex that keeps this line fed."},
			{"speaker": "Commander", "text": "That sounded dangerously close to a compliment."},
			{"speaker": "Kaelen", "text": "Don't pin a medal on it. I'm saying I stake supplies on you now—not on your epitaph."},
			{"speaker": "Commander", "text": "Sounds like trust."},
			{"speaker": "Kaelen", "text": "Call it accounting. Dead commanders waste good maps. Alive ones still annoy me—I'll take annoyance."},
			{"speaker": "Commander", "text": "I'll take that deal."},
			{"speaker": "Kaelen", "text": "Good. Next time grief tries to jump the queue, breathe first anyway—you'll remember why I harp on it."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_kaelen_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_liora_callback",
		"primary_unit": "Liora",
		"participants": ["Liora", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 11,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_liora_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Liora", "text": "After Valeron, I promised myself plain language. So here it is: I stay beside you because I choose to—not because any rite taught me the choreography."},
			{"speaker": "Commander", "text": "You don't owe me a confession."},
			{"speaker": "Liora", "text": "It is not a confession. It is a fact. I am slower with sacred phrasing now; quicker with water, food, and sleep nobody has to earn as punishment."},
			{"speaker": "Commander", "text": "That's care."},
			{"speaker": "Liora", "text": "The unglamorous kind. If my hand finds yours in the dark and surprises you, blame the Trial for reminding me time is finite—not symbolic."},
			{"speaker": "Commander", "text": "It won't surprise me."},
			{"speaker": "Liora", "text": "...Then I will try to believe you mean that—before my courage runs out for the night."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_liora_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_darian_callback",
		"primary_unit": "Darian",
		"participants": ["Darian", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 6,
		"min_personal_arc_stage": 1,
		"required_arc_flags": ["dc_camp_avatar_darian_1"],
		"once_ever": true,
		"script": [
			{"speaker": "Darian", "text": "You knocked twice. I didn't realize how long I'd been waiting for someone to mean it."},
			{"speaker": "Commander", "text": "You answered like it mattered."},
			{"speaker": "Darian", "text": "It did. The public fool can stay—he pays for the larder. Privately, I'm allowed anger and tenderness in the same breath now."},
			{"speaker": "Commander", "text": "Anger without theater?"},
			{"speaker": "Darian", "text": "Controlled heat. If I polish a lie at your table again, tell me—I'll trade polish for honesty even if the room goes quiet."},
			{"speaker": "Commander", "text": "Deal."},
			{"speaker": "Darian", "text": "Good. Two knocks, no audience—that's the treaty I'm holding to. Mask for them; spine for us."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_darian_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_meris_callback",
		"primary_unit": "Sister Meris",
		"participants": ["Sister Meris", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 7,
		"min_personal_arc_stage": 1,
		"required_arc_flags": ["dc_camp_avatar_meris_1"],
		"once_ever": true,
		"script": [
			{"speaker": "Sister Meris", "text": "Brother Alden caught me handing bread before questions yesterday. Old me would've called it interference. Present me calls it practice."},
			{"speaker": "Commander", "text": "Keep practicing."},
			{"speaker": "Sister Meris", "text": "I intend to. Mercy isn't a debate prize anymore—it's what I do when someone's hands shake too hard to confess cleanly."},
			{"speaker": "Commander", "text": "That costs you sleep."},
			{"speaker": "Sister Meris", "text": "Sleep returns. Dignity stolen in haste doesn't. Your 'bread before verdict' line stuck because it was work—not a slogan."},
			{"speaker": "Commander", "text": "Alden would say the same."},
			{"speaker": "Sister Meris", "text": "He did—without making me feel small for needing the echo. I'm learning to trust the reflex even when my old teachers hiss."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_meris_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_hest_callback",
		"primary_unit": "Hest \"Sparks\"",
		"participants": ["Hest \"Sparks\"", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 7,
		"min_personal_arc_stage": 1,
		"required_arc_flags": ["dc_camp_avatar_hest_1"],
		"once_ever": true,
		"script": [
			{"speaker": "Hest \"Sparks\"", "text": "I've been building slow on purpose—like you ordered. Turns out dull doesn't feel like a verdict when someone remembers your name between jokes."},
			{"speaker": "Commander", "text": "Dull was always the point."},
			{"speaker": "Hest \"Sparks\"", "text": "Yeah—my hands believe it now. Clamps tight, punchlines soft, nobody betting their fingers on a flourish."},
			{"speaker": "Commander", "text": "Less disposable?"},
			{"speaker": "Hest \"Sparks\"", "text": "Less 'temporary' with a capital stink I've been pretending was wit. If the bread-and-clamps promise still stands, I'm not auditioning to be swapped out next week."},
			{"speaker": "Commander", "text": "You stay on the roster."},
			{"speaker": "Hest \"Sparks\"", "text": "Good. Say it again when I'm not laughing—sparse words, like you meant. I hear those better. Still do."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_hest_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_ser_hadrien_callback",
		"primary_unit": "Ser Hadrien",
		"participants": ["Ser Hadrien", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 18,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_ser_hadrien_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Ser Hadrien", "text": "Rain came in sideways on second relief—the knots drank it and pretended they didn't. I walked the line anyway."},
			{"speaker": "Commander", "text": "That's not in your oath."},
			{"speaker": "Ser Hadrien", "text": "My oath outgrew the abstractions. Wet rope shrinks; lanterns gutter; throats go dry while someone still argues purity in a dry tent."},
			{"speaker": "Commander", "text": "You fixed what you could."},
			{"speaker": "Ser Hadrien", "text": "I re-seated cord, swapped a warped stake, left wax where leather was learning to lie. Small work—loyalty without theater."},
			{"speaker": "Commander", "text": "Thank you."},
			{"speaker": "Ser Hadrien", "text": "Don't thank the Order's shadow—thank the practice. I'm done winning debates with ghosts; I'd rather your watch stay honest in weather."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_ser_hadrien_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_darian_aftermath_callback",
		"primary_unit": "Darian",
		"participants": ["Darian", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 7,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_darian_callback"],
		"once_ever": true,
		"script": [
			{"speaker": "Darian", "text": "Kettle's thinning—ration math, not scandal. I set a second bowl by the small table anyway."},
			{"speaker": "Commander", "text": "You didn't have to."},
			{"speaker": "Darian", "text": "That's the point. No flourish, no punchline—just heat while it's honest. Performance stays at the fire line."},
			{"speaker": "Commander", "text": "This is the treaty."},
			{"speaker": "Darian", "text": "Deliberate warmth when it matters. Wry still leaks out—I can't unlearn my mouth—but the bowl isn't a trick."},
			{"speaker": "Commander", "text": "I'll eat it."},
			{"speaker": "Darian", "text": "Good. Elegant is how I survive them; gentle is how I'm choosing to survive us."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_darian_aftermath_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_veska_callback",
		"primary_unit": "Veska Moor",
		"participants": ["Veska Moor", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 8,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_veska_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Veska Moor", "text": "Shield rack stank of old blood in the grooves—someone polished the face and forgot the rim."},
			{"speaker": "Commander", "text": "I'll detail a scrub."},
			{"speaker": "Veska Moor", "text": "Already ordered—salt, rag, no speech. While they worked, East relief tried to open with a motto. I fed them first."},
			{"speaker": "Commander", "text": "Bread before the banner."},
			{"speaker": "Veska Moor", "text": "Bread, water, strap check—then words if there's breath left. Bodies don't need poetry when shoulders are grinding."},
			{"speaker": "Commander", "text": "Understood."},
			{"speaker": "Veska Moor", "text": "I'm not asking permission anymore for that order—it's how I hand off. Dependable work, plain authority; rhetoric can catch up wet if it wants."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_veska_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_corvin_callback",
		"primary_unit": "Corvin Ash",
		"participants": ["Corvin Ash", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 9,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_corvin_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Corvin Ash", "text": "Damp climbed the tent seam—three pages went soft before anyone smelled it."},
			{"speaker": "Commander", "text": "Casualties?"},
			{"speaker": "Corvin Ash", "text": "Ink, not people—this time. I pulled the cold stack, aired it, marked the shelf with charcoal like we do bread."},
			{"speaker": "Commander", "text": "That's new."},
			{"speaker": "Corvin Ash", "text": "Stewardship. Truth isn't only accurate once—it's kept from rotting where virtue forgets to look."},
			{"speaker": "Commander", "text": "Keep the watch."},
			{"speaker": "Corvin Ash", "text": "I will—nightly edges, fingerprints logged. Unsettling work, unsentimental habit; I'd rather maintain memory than eulogize it."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_corvin_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_meris_aftermath_callback",
		"primary_unit": "Sister Meris",
		"participants": ["Sister Meris", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 8,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_meris_callback"],
		"once_ever": true,
		"script": [
			{"speaker": "Sister Meris", "text": "Cot tags were wrong—two names swapped by hurry. I caught it before ink, not after conscience."},
			{"speaker": "Commander", "text": "Good catch."},
			{"speaker": "Sister Meris", "text": "Discipline, not drama—candle stub, water first, file opens only when breath slows. I'm not debating the Church in my head anymore."},
			{"speaker": "Commander", "text": "You're just doing it."},
			{"speaker": "Sister Meris", "text": "Yes. Humane rule: small, repeatable, dull as mercy should be when it works."},
			{"speaker": "Commander", "text": "Keep the order."},
			{"speaker": "Sister Meris", "text": "I will—quiet rounds, no sermon in the margin. Conscience lives in the habit now, not the argument."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_meris_aftermath_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_hest_aftermath_callback",
		"primary_unit": "Hest \"Sparks\"",
		"participants": ["Hest \"Sparks\"", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 8,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_hest_callback"],
		"once_ever": true,
		"script": [
			{"speaker": "Hest \"Sparks\"", "text": "Spare rig got a chalk box—my mark, not 'next available idiot.' Quartermaster squinted; I smiled until he stopped."},
			{"speaker": "Commander", "text": "That official?"},
			{"speaker": "Hest \"Sparks\"", "text": "Official enough. Belonging tastes like parts that remember your name—inventory that doesn't treat you like weather."},
			{"speaker": "Commander", "text": "Still joking?"},
			{"speaker": "Hest \"Sparks\"", "text": "Always—nervous insulation's a hard habit. Difference is the build underneath: clamps torqued like I'm staying, not visiting."},
			{"speaker": "Commander", "text": "Good."},
			{"speaker": "Hest \"Sparks\"", "text": "Trust practiced beats trust hypothetical. Say 'on the roster' again when I'm not performing—I'll hear it the same."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_hest_aftermath_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_alden_callback",
		"primary_unit": "Brother Alden",
		"participants": ["Brother Alden", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 6,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_alden_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Brother Alden", "text": "That fever case you let stay horizontal—he drank on his own this morning. No sermon required. The tent noticed anyway."},
			{"speaker": "Commander", "text": "Good."},
			{"speaker": "Brother Alden", "text": "Good is habit now, not argument. I've stopped rehearsing the lecture about pageantry—my hands move to water and shade before my pride remembers it likes to win."},
			{"speaker": "Commander", "text": "You sound almost peaceful about that."},
			{"speaker": "Brother Alden", "text": "Peaceful is a strong word. Efficient is honest. Mercy that waits for permission isn't mercy—it's theater with better lighting."},
			{"speaker": "Commander", "text": "Keep doing what you're doing."},
			{"speaker": "Brother Alden", "text": "I will—without asking you to applaud it. Triage doesn't end at the cots, Commander… and neither does the quiet work of letting people heal like bodies, not banners."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_alden_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_yselle_callback",
		"primary_unit": "Yselle Maris",
		"participants": ["Yselle Maris", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 7,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_yselle_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Yselle Maris", "text": "I kept the polished face for the line tonight—linen where panic looks for something to lean on."},
			{"speaker": "Commander", "text": "And with me?"},
			{"speaker": "Yselle Maris", "text": "Crooked cups. No apology for the tremor. That's the intimacy I mean now—chosen, not smuggled out of duty."},
			{"speaker": "Commander", "text": "You don't owe me the unarmored version."},
			{"speaker": "Yselle Maris", "text": "I know. That's why I'm offering it—armor for them, honesty for us. Elegance isn't the enemy; pretending I'm never tired is."},
			{"speaker": "Commander", "text": "Then sit like you're not on display."},
			{"speaker": "Yselle Maris", "text": "Already doing it. If my hands shake, it's real—and if it's real, the camp can borrow my calm tomorrow without buying a myth about tonight."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_yselle_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_maela_callback",
		"primary_unit": "Maela Thorn",
		"participants": ["Maela Thorn", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 25,
		"req_level": 8,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_maela_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Maela Thorn", "text": "Yesterday's mud drill held—nobody postured their way into a limp. That's not luck; that's ownership."},
			{"speaker": "Commander", "text": "You sound like you're done proving."},
			{"speaker": "Maela Thorn", "text": "I'm done auditioning for ghosts. The ring answers to me now—not to every old voice that called me too small to matter."},
			{"speaker": "Commander", "text": "Good."},
			{"speaker": "Maela Thorn", "text": "Steady means boring on purpose. Boring is how you keep air for orders instead of spending it on performance."},
			{"speaker": "Commander", "text": "Keep the standard."},
			{"speaker": "Maela Thorn", "text": "I will—same hips for me as for them. Confidence isn't louder reps; it's knowing the work holds when nobody's watching."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_maela_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_rufus_callback",
		"primary_unit": "Rufus",
		"participants": ["Rufus", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 25,
		"req_level": 7,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_rufus_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Rufus", "text": "Someone tried to 'borrow courage' from my issue pile again—wanted a blessing and a shortcut."},
			{"speaker": "Commander", "text": "Do you want me to shut it down?"},
			{"speaker": "Rufus", "text": "I already did—with language that left a mark. Heat and weight aren't polite; they're honest."},
			{"speaker": "Commander", "text": "That sounds like you trust the line a little more."},
			{"speaker": "Rufus", "text": "I trust what I can measure—and I invest bluntness where soft lies would cost fingers. That's respect, not suspicion."},
			{"speaker": "Commander", "text": "I'll back the forge over theater."},
			{"speaker": "Rufus", "text": "Good. If you're near my fire, you're under my truth—I'll bruise egos early so shoulders stay attached."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_rufus_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_mira_callback",
		"primary_unit": "Mira Ashdown",
		"participants": ["Mira Ashdown", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 25,
		"req_level": 9,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_mira_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Mira Ashdown", "text": "Wind day came back. Half the line wanted a hero shot; the other half needed strings that wouldn't lie."},
			{"speaker": "Commander", "text": "Which won?"},
			{"speaker": "Mira Ashdown", "text": "Boring competence—shared, slow, counted. Nobody shamed the shake; we drilled through it until the shake had a number."},
			{"speaker": "Commander", "text": "That's trust."},
			{"speaker": "Mira Ashdown", "text": "It's slower than pride likes. I'd rather own slow truth with you than chase a clean score that hid the hurry."},
			{"speaker": "Commander", "text": "Keep sharpening without closing off."},
			{"speaker": "Mira Ashdown", "text": "That's the bargain—edges for the work, patience for the people holding the bows. I'll meet you in the ugly middle."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_mira_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_pell_callback",
		"primary_unit": "Pell Rowan",
		"participants": ["Pell Rowan", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 7,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_pell_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Pell Rowan", "text": "Relay yesterday—voice shook once on the second count. I didn't try to hide it. I finished true."},
			{"speaker": "Commander", "text": "That's the job."},
			{"speaker": "Pell Rowan", "text": "I know. That's what changed—I'm not begging to be noiseless anymore. I'm holding reliability while the fear does its honest work."},
			{"speaker": "Commander", "text": "Less fear of being the weak link?"},
			{"speaker": "Pell Rowan", "text": "Fear's still there—earned steadiness means carrying it without letting it steer the call."},
			{"speaker": "Commander", "text": "Good."},
			{"speaker": "Pell Rowan", "text": "Dry runs bought me that. Ugly courage was the start; steady truth under pressure is what I'm trying to keep."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_pell_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_oren_callback",
		"primary_unit": "Oren Pike",
		"participants": ["Oren Pike", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 25,
		"req_level": 7,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_oren_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Oren Pike", "text": "Last night's march window—you took the boring hour I asked for. Stakes held. Ankles stayed honest."},
			{"speaker": "Commander", "text": "Your map earned the delay."},
			{"speaker": "Oren Pike", "text": "Maps don't carry stretchers—you do. I'm done treating skepticism like my only tool; field authority means signing ugly margins you can defend with bodies, not ink."},
			{"speaker": "Commander", "text": "You want judgment on the page."},
			{"speaker": "Oren Pike", "text": "I want consequences beside distances—so when someone 'optimizes,' they see who pays."},
			{"speaker": "Commander", "text": "Keep writing it plain."},
			{"speaker": "Oren Pike", "text": "I will. Trusted engineer means you sleep behind my lines—not behind a story told by people who never hauled rope in rain."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_oren_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_tariq_callback",
		"primary_unit": "Tariq",
		"participants": ["Tariq", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 8,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_tariq_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Tariq", "text": "The latest rumor tried to buy your death wholesale—interest included. I didn't trim alone; I left the raw numbers where you'd have to look."},
			{"speaker": "Commander", "text": "You used to sell cleaner packages."},
			{"speaker": "Tariq", "text": "Patronage taught me polish. This camp taught me shared responsibility—if the translation cuts, you should feel the blade beside me, not rent my mouth."},
			{"speaker": "Commander", "text": "That's more trust than solitary editing."},
			{"speaker": "Tariq", "text": "Truth stays sharp—I'm just done pretending sharp means solitary. We both pay for clarity now; that's fairer than martyrdom dressed as dialect."},
			{"speaker": "Commander", "text": "Keep the miser-words."},
			{"speaker": "Tariq", "text": "Always—earned syllables only. If the camp flinches, they'll flinch at facts we chose together."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_tariq_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_sabine_callback",
		"primary_unit": "Sabine Varr",
		"participants": ["Sabine Varr", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 25,
		"req_level": 8,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_sabine_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Sabine Varr", "text": "Rotations bent last night—mud disagreed with the pretty timetable. Sergeants held the spine while I stayed in the gap with the names."},
			{"speaker": "Commander", "text": "Casualties?"},
			{"speaker": "Sabine Varr", "text": "None heroic—just tired. That's the point: adaptive systems beat my old habit of gripping the ledger until grief suffocated."},
			{"speaker": "Commander", "text": "You sound lighter."},
			{"speaker": "Sabine Varr", "text": "Lighter is wrong. Present. Delegated steadiness means I grieve where it belongs—in the room, not under procedure."},
			{"speaker": "Commander", "text": "Keep the fractures small."},
			{"speaker": "Sabine Varr", "text": "Small breaks, same wall—I'll trust the line to bend and return. Vigilance without burial. That's the next version I'm holding."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_sabine_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_avatar_inez_callback",
		"primary_unit": "Inez",
		"participants": ["Inez", "Commander"],
		"conversation_type": "support",
		"priority": 25,
		"req_level": 9,
		"min_personal_arc_stage": 2,
		"required_arc_flags": ["dc_camp_avatar_inez_2"],
		"once_ever": true,
		"script": [
			{"speaker": "Inez", "text": "You came back to the tree line without your title shouting first. The soil noticed."},
			{"speaker": "Commander", "text": "I'm learning."},
			{"speaker": "Inez", "text": "Learning used to be a private treaty between you and your rank. Now it sounds like a person—still quiet, less self-contained."},
			{"speaker": "Commander", "text": "I'll take that."},
			{"speaker": "Inez", "text": "Good. I still listen to land before mouths—but I leave the flap open after, in case you meant to stay past the correction."},
			{"speaker": "Commander", "text": "I meant to."},
			{"speaker": "Inez", "text": "Then sit. Not for instruction—for company. Grounded presence costs less than distance dressed as discipline."},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_inez_callback", "add_avatar_relationship": 2},
	},
	{
		"id": "dc_camp_alden_commander_water_habit_checkin",
		"primary_unit": "Brother Alden",
		"participants": ["Brother Alden", "Commander"],
		"conversation_type": "camp_checkin",
		"priority": 17,
		"req_level": 6,
		"min_personal_arc_stage": 3,
		"required_arc_flags": ["dc_camp_avatar_alden_callback"],
		"once_per_visit": true,
		"script": [
			{"speaker": "Brother Alden", "text": "Cup's already poured—drink before you argue. Habit, not heroics."},
			{"speaker": "Commander", "text": "…Yes, Brother."},
			{"speaker": "Brother Alden", "text": "Good. The tent's learning the same rule: mercy first, speech after—if speech comes at all."},
		],
		"effects_on_complete": {"add_avatar_relationship": 1},
	},
	{
		"id": "dc_camp_yselle_commander_quiet_table_checkin",
		"primary_unit": "Yselle Maris",
		"participants": ["Yselle Maris", "Commander"],
