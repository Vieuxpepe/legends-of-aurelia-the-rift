		"req_level": 1,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Celia", "text": "Kaelen said my stance was better. I still feel like I'm pretending."},
			{"speaker": "Commander", "text": "Pretending is how bodies learn before belief catches up."},
			{"speaker": "Celia", "text": "Easy for you to say. Everyone watches you like the world pivots when you move."},
			{"speaker": "Commander", "text": "They watch you too. That's the job."},
			{"speaker": "Celia", "text": "When I fail, I don't want it to be because I wanted mercy from myself. Should I be harder—or is that how I break?"},
		],
		"choices": [
			{
				"text": "Be precise, not cruel. Precision is enough.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "Hardness without aim is just noise. Aim small. Repeat it until it's honest."},
					{"speaker": "Celia", "text": "...Small. Right."},
					{"speaker": "Celia", "text": "I can do small. I can do it until my shoulders stop arguing."},
					{"speaker": "Commander", "text": "Then you're not pretending anymore."},
					{"speaker": "Celia", "text": "Don't say that too loudly. I'll get cocky and miss a step."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "Be hard. Softness costs lives on a wall.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "The line doesn't need your doubt. It needs your count."},
					{"speaker": "Celia", "text": "Understood."},
					{"speaker": "Celia", "text": "If I go quiet after, it's not sulking. It's me tightening down."},
					{"speaker": "Commander", "text": "Check in with me anyway."},
					{"speaker": "Celia", "text": "That's soft too, Commander. Fine. I'll knock."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_celia_1"},
	},
	{
		"id": "dc_camp_avatar_celia_2",
		"primary_unit": "Celia",
		"participants": ["Celia", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 19,
		"req_level": 5,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Celia", "text": "Same pass drill. Same slip—third count. The line isn't cruel; it's clocking me like a lesson they're tired of sitting through."},
			{"speaker": "Commander", "text": "You hear them."},
			{"speaker": "Celia", "text": "I hear myself wondering if mercy from my own body reads as weakness they were right to expect from someone… shaped like I was."},
			{"speaker": "Commander", "text": "What do you need from me right now?"},
			{"speaker": "Celia", "text": "An order I can obey without performing pain: patience—boring reps until the muscle stops arguing—or severity, until nobody can say I didn't bleed effort where they could see it?"},
		],
		"choices": [
			{
				"text": "Patience. Small reps until it's true.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "No theater. Fix the step until it's boring. Boring is how you stop borrowing worth from other people's eyes."},
					{"speaker": "Celia", "text": "...Boring. Right. That's harder than bruises. Good."},
					{"speaker": "Celia", "text": "I'll take the quiet reps. If they whisper, let them. My body can learn without an audience shaming it faster."},
					{"speaker": "Commander", "text": "I'll run the drill with you once—slow."},
					{"speaker": "Celia", "text": "Don't spare me because you pity the girl who learned to stand still in rooms that wanted her grateful. Spare me the lie that hurry is virtue."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "Severity. Show them you're willing to break sweat.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "Double the set. Let them see effort—controlled, not sloppy."},
					{"speaker": "Celia", "text": "Understood. If I shake, I'll shake where it counts."},
					{"speaker": "Celia", "text": "Just—after, remind me that's not the only way I'm allowed to improve. I confuse being watched with being proven."},
					{"speaker": "Commander", "text": "I'll remind you."},
					{"speaker": "Celia", "text": "Thank you. Even when severity is the medicine, I don't want it to become my name."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_celia_2"},
	},
	{
		"id": "dc_camp_avatar_garrick_1",
		"primary_unit": "Garrick Vale",
		"participants": ["Garrick Vale", "Commander"],
		"conversation_type": "support",
		"priority": 18,
		"req_level": 5,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Garrick Vale", "text": "You corrected a sentry in front of the watch. Public. Sharp."},
			{"speaker": "Commander", "text": "They missed a call. It mattered."},
			{"speaker": "Garrick Vale", "text": "It always matters. The question is whether the lesson lands—or whether you just taught the camp to fear your voice."},
			{"speaker": "Commander", "text": "Fear keeps people awake."},
			{"speaker": "Garrick Vale", "text": "So does respect. Pick which one you want carrying your orders when you're not there to glare."},
		],
		"choices": [
			{
				"text": "Respect. I'll apologize to the sentry and restate the standard.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "Fair. I can be right and still cost us trust."},
					{"speaker": "Garrick Vale", "text": "Good. That's officer thinking, not pride thinking."},
					{"speaker": "Garrick Vale", "text": "I'll walk the line with you after. Let them see correction without humiliation."},
					{"speaker": "Commander", "text": "You don't have to babysit me."},
					{"speaker": "Garrick Vale", "text": "I'm not babysitting. I'm keeping the wall from learning the wrong lesson about you."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "Discipline first. Soft words later.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "If I cushion every mistake, we die polite."},
					{"speaker": "Garrick Vale", "text": "If you never cushion, you train obedience without judgment. That's how blind spots form."},
					{"speaker": "Garrick Vale", "text": "Do what you must. Just know I'll be fixing what your tone breaks."},
					{"speaker": "Commander", "text": "That's your job."},
					{"speaker": "Garrick Vale", "text": "And yours is to win more than one night. Think longer."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_garrick_1"},
	},
	{
		"id": "dc_camp_avatar_garrick_2",
		"primary_unit": "Garrick Vale",
		"participants": ["Garrick Vale", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 17,
		"req_level": 8,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Garrick Vale", "text": "Weather'll cut visibility before midnight. Section leaders want reliefs staggered—fifteen minutes' drift so fresh eyes meet fresh mistakes."},
			{"speaker": "Commander", "text": "Drift opens gaps."},
			{"speaker": "Garrick Vale", "text": "A sacred clock opens blind handoffs when nobody can see the rope. I've watched manuals win arguments and lose throats."},
			{"speaker": "Commander", "text": "What are you recommending?"},
			{"speaker": "Garrick Vale", "text": "Choose your architecture: one order from you—clean, traceable—or delegated judgment from sergeants who know the mud under their boots. Stability on paper… or adaptation that outruns the map?"},
		],
		"choices": [
			{
				"text": "Let the sections adapt. I'll back their calls.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "Issue the intent: hold the wall, no blind reliefs. How they stagger is theirs—within bounds."},
					{"speaker": "Garrick Vale", "text": "Good. Command that trusts judgment trains judgment. Command that fears it trains obedience without eyes."},
					{"speaker": "Garrick Vale", "text": "I'll audit after—not to punish, to learn which mud lied."},
					{"speaker": "Commander", "text": "Send me the notes."},
					{"speaker": "Garrick Vale", "text": "You'll get them plain. Institutions survive on memory; armies survive on what people do when the ink's wet."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "Hold the clock. I'll own the risk of rigid relief.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "One timetable. Less room for improvisation to become excuse."},
					{"speaker": "Garrick Vale", "text": "Understood. Then double the lantern checks and place a runner on the worst face—I'll volunteer the route."},
					{"speaker": "Commander", "text": "You're not my courier."},
					{"speaker": "Garrick Vale", "text": "I'm the officer who still believes structure should protect bodies, not pride. If the clock's fixed, the bodies need padding."},
					{"speaker": "Commander", "text": "Do it."},
					{"speaker": "Garrick Vale", "text": "When the night goes wrong, we'll know whether it was weather… or refusal to bend. I'll want that answer honest."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_garrick_2"},
	},
	{
		"id": "dc_camp_avatar_tariq_1",
		"primary_unit": "Tariq",
		"participants": ["Tariq", "Commander"],
		"conversation_type": "support",
		"priority": 18,
		"req_level": 3,
		"once_ever": true,
		"script": [
			{"speaker": "Tariq", "text": "Camp rumor has you dying three different deaths before breakfast. I admire the variety."},
			{"speaker": "Commander", "text": "Should I be flattered?"},
			{"speaker": "Tariq", "text": "Be precise. Rumor is a dialect. If you don't translate it, it translates you."},
			{"speaker": "Commander", "text": "What are they actually afraid of?"},
			{"speaker": "Tariq", "text": "Change. You are inconveniently alive, which forces them to revise their stories mid-sentence."},
			{"speaker": "Commander", "text": "And you?"},
			{"speaker": "Tariq", "text": "I revise for a living. Bring me the next wild tale—I will trim the adjectives and leave you something usable."},
		],
		"effects_on_complete": {"add_avatar_relationship": 2, "advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_tariq_1"},
	},
	{
		"id": "dc_camp_avatar_rufus_1",
		"primary_unit": "Rufus",
		"participants": ["Rufus", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 17,
		"req_level": 3,
		"once_ever": true,
		"script": [
			{"speaker": "Rufus", "text": "If you're here to 'inspire' the forge, save it. I've watched men invoice inspiration while someone else coughed coal."},
			{"speaker": "Commander", "text": "I need two hinge pins by dusk. No theater."},
			{"speaker": "Rufus", "text": "Good. Work I can weigh. Speeches drift off and land on the wrong shoulders."},
			{"speaker": "Commander", "text": "Can you do it?"},
			{"speaker": "Rufus", "text": "Ask like you mean the job—not like you're bracing for me to punish you for needing labor."},
			{"speaker": "Commander", "text": "Two hinge pins. Dusk. Can you deliver?"},
			{"speaker": "Rufus", "text": "Yes. Pick them up warm. Heat doesn't lie; people do."},
		],
		"effects_on_complete": {"add_avatar_relationship": 2, "advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_rufus_1"},
	},
	{
		"id": "dc_camp_avatar_rufus_2",
		"primary_unit": "Rufus",
		"participants": ["Rufus", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 16,
		"req_level": 5,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Rufus", "text": "Someone asked me to bless the replacements before issue. I told them the quench tank isn't holy water."},
			{"speaker": "Commander", "text": "Do you want that shut down?"},
			{"speaker": "Rufus", "text": "I want you to choose what this army trusts—heat, temper, and honest weight… or a story so the line can pretend steel cares about intentions."},
			{"speaker": "Commander", "text": "What are you asking me to do?"},
			{"speaker": "Rufus", "text": "Pick whether morale comes out of my mouth… or out of work loud enough nobody has to perform courage for the fire."},
		],
		"choices": [
			{
				"text": "Forge only. No blessings—let the work speak.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "I'll back metal and sweat. If they want meaning, they can learn at the anvil."},
					{"speaker": "Rufus", "text": "Good. Blistered honesty ages better than slogans."},
					{"speaker": "Rufus", "text": "Bent steel comes back to the yard. Anyone treating issue like theater can file until their hands remember what labor is."},
					{"speaker": "Commander", "text": "I'll make the expectation clear."},
					{"speaker": "Rufus", "text": "Clear is kindness. On the docks we called it keeping ten fingers."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "One line at issue—plain—then silence.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "Symbols matter. I need one clean sentence—not a sermon, not mockery."},
					{"speaker": "Rufus", "text": "Hmph. One line buys quiet if it's the right line."},
					{"speaker": "Rufus", "text": "I'll say it: hold what you're given like you mean to come home. After that they get my face, which says the rest."},
					{"speaker": "Commander", "text": "That works."},
					{"speaker": "Rufus", "text": "Don't make a habit of it. Speeches rot faster than unpainted iron."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_rufus_2"},
	},
	{
		"id": "dc_camp_avatar_alden_1",
		"primary_unit": "Brother Alden",
		"participants": ["Brother Alden", "Commander"],
		"conversation_type": "support",
		"priority": 18,
		"req_level": 3,
		"once_ever": true,
		"script": [
			{"speaker": "Brother Alden", "text": "You drink water like it's an afterthought. Your hands disagree."},
			{"speaker": "Commander", "text": "I'm busy."},
			{"speaker": "Brother Alden", "text": "So is every fever I treat. Busy is not an argument; it's a habit."},
			{"speaker": "Commander", "text": "What do you want?"},
			{"speaker": "Brother Alden", "text": "Ten minutes. Sit. Breathe like you mean to keep the body you're borrowing."},
			{"speaker": "Commander", "text": "...That's annoyingly gentle."},
			{"speaker": "Brother Alden", "text": "Gentle is cheaper than stitches. Humor me."},
		],
		"effects_on_complete": {"add_avatar_relationship": 2, "advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_alden_1"},
	},
	{
		"id": "dc_camp_avatar_alden_2",
		"primary_unit": "Brother Alden",
		"participants": ["Brother Alden", "Commander"],
		"conversation_type": "support",
		"priority": 16,
		"req_level": 5,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Brother Alden", "text": "Third cot—fever burning clean through the prayers we keep saying over him. He'll live if we let him lie still. Moving him again would only feed the tent's appetite for visible miracles."},
			{"speaker": "Commander", "text": "They want him where the line can see him heal."},
			{"speaker": "Brother Alden", "text": "I spent years watching institutions win arguments with the dying because the story looked tidy. Faith without a body is just theater with incense."},
			{"speaker": "Commander", "text": "You're asking me to choose."},
			{"speaker": "Brother Alden", "text": "Body first—quiet, boring recovery—or usefulness first, parading improvement so everyone feels blessed. Which conscience do you want tonight… the pulse… or the ideal?"},
		],
		"choices": [
			{
				"text": "The pulse. He stays horizontal. I'll handle the tent.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "No processions. If they need hope, they can wash basins instead of gawking."},
					{"speaker": "Brother Alden", "text": "Good. Hope that costs someone breath isn't hope—it's audience."},
					{"speaker": "Brother Alden", "text": "I'll sit the fever myself. Not as spectacle—as weight. Hands stay busy so mouths don't invent sermons."},
					{"speaker": "Commander", "text": "You should sleep too."},
					{"speaker": "Brother Alden", "text": "When he's through the worst. Rest isn't kindness if it arrives after the damage—it's just scheduling. I learned that where you learn most honest things: carrying people who can't carry themselves."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "One short visit—then bed and silence. Split the difference.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "Give them a glimpse—two minutes—then you close the flap. No second parade."},
					{"speaker": "Brother Alden", "text": "A compromise that still spends him. I'll allow it—if you stand there and look bored while it happens."},
					{"speaker": "Commander", "text": "Bored?"},
					{"speaker": "Brother Alden", "text": "Bored is honest. Excitement turns grief into festival. If you're going to borrow his body for morale, at least don't dress it as holiness."},
					{"speaker": "Commander", "text": "...Understood."},
					{"speaker": "Brother Alden", "text": "Good. And Commander—when this is over, drink water like you mean it. Triage doesn't end at the cots."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_alden_2"},
	},
	{
		"id": "dc_camp_avatar_mira_1",
		"primary_unit": "Mira Ashdown",
		"participants": ["Mira Ashdown", "Commander"],
		"conversation_type": "support",
		"priority": 18,
		"req_level": 4,
		"once_ever": true,
		"script": [
			{"speaker": "Mira Ashdown", "text": "The new archers flinch when they draw. Not from fear—from wanting to look good."},
			{"speaker": "Commander", "text": "You want me to talk to them?"},
			{"speaker": "Mira Ashdown", "text": "I want you to stop treating 'good enough' like an insult. It's how accuracy survives when the world gets loud."},
			{"speaker": "Commander", "text": "That's softer than I expected."},
			{"speaker": "Mira Ashdown", "text": "Soft is letting someone snap a string in their face because pride said hurry. I've heard what hurry sounds like. I don't confuse noise with truth."},
			{"speaker": "Commander", "text": "Point taken."},
			{"speaker": "Mira Ashdown", "text": "I'll drill them slow until their shoulders stop performing. You keep the camp from mocking slow work—mockery turns patience into shame, and shame makes liars of the hands."},
		],
		"effects_on_complete": {"add_avatar_relationship": 2, "advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_mira_1"},
	},
	{
		"id": "dc_camp_avatar_mira_2",
		"primary_unit": "Mira Ashdown",
		"participants": ["Mira Ashdown", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 17,
		"req_level": 8,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Mira Ashdown", "text": "Wind's picking up. The ones who rush the shot will blame the bow."},
			{"speaker": "Commander", "text": "You want the exercise called off?"},
			{"speaker": "Mira Ashdown", "text": "I want a decision about what we teach: patience as permission… or patience as delay while the camp watches for heroes."},
			{"speaker": "Commander", "text": "Explain the trade."},
			{"speaker": "Mira Ashdown", "text": "Drill ugly and slow until the stance holds—or push speed now so the line looks capable before supper. Accuracy without applause… or performance that might cost someone's face tomorrow?"},
		],
		"choices": [
			{
				"text": "Ugly and slow until it's true.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "No prizes for fast misses. I'll tell them boring is the point."},
					{"speaker": "Mira Ashdown", "text": "Good. The world's loud enough without us adding theater to archery."},
					{"speaker": "Mira Ashdown", "text": "I'll keep corrections small. Small erases bad habits without shaming people stiff."},
					{"speaker": "Commander", "text": "You have the hours."},
					{"speaker": "Mira Ashdown", "text": "Hours are the honest part. Shortcuts are sold with someone else's blood."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "Show progress today—tight margins only.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "Morale can't eat patience raw. Give them something visible—contained."},
					{"speaker": "Mira Ashdown", "text": "Visible is a hungry animal. I'll leash it."},
					{"speaker": "Mira Ashdown", "text": "Short ends only. Anyone flexing for the fire gets pulled—I'll embarrass them before the string does."},
					{"speaker": "Commander", "text": "Do it."},
					{"speaker": "Mira Ashdown", "text": "I'll hold you to the margin. Pride and grief both lie about distance."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_mira_2"},
	},
	{
		"id": "dc_camp_avatar_pell_1",
		"primary_unit": "Pell Rowan",
		"participants": ["Pell Rowan", "Commander"],
		"conversation_type": "support",
		"priority": 17,
		"req_level": 2,
		"once_ever": true,
		"script": [
			{"speaker": "Pell Rowan", "text": "Sir—Commander—I had it perfect in my head. The kind of clear they put in stories. Then my mouth tried to be worthy and turned traitor."},
			{"speaker": "Commander", "text": "You're allowed to be nervous."},
			{"speaker": "Pell Rowan", "text": "Not on the wall I'm not. Nervous rattles—and I can't be the boy who practiced courage and still became noise."},
			{"speaker": "Commander", "text": "Then carry nervous like weight, not like sound. One breath, one call."},
			{"speaker": "Pell Rowan", "text": "...One breath. One call."},
			{"speaker": "Commander", "text": "Again."},
			{"speaker": "Pell Rowan", "text": "North clear. East—east clear. Better?"},
			{"speaker": "Commander", "text": "Better enough. Keep the second one ugly if you have to. Just make it true—truth is the only kind of brave that holds."},
		],
		"effects_on_complete": {"add_avatar_relationship": 2, "advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_pell_1"},
	},
	{
		"id": "dc_camp_avatar_pell_2",
		"primary_unit": "Pell Rowan",
		"participants": ["Pell Rowan", "Commander"],
		"conversation_type": "support",
		"priority": 16,
		"req_level": 5,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Pell Rowan", "text": "Relay duty tomorrow. If I botch the count, it's not my pride—it's the next man's timing."},
			{"speaker": "Commander", "text": "You're not on the wall alone."},
			{"speaker": "Pell Rowan", "text": "Alone isn't what scares me. Being the weak link is. I wanted to be… shining. Songs don't mention how much of courage is just not rattling."},
			{"speaker": "Commander", "text": "What do you need from me?"},
			{"speaker": "Pell Rowan", "text": "Which officer are you—the one who steadies a shaking voice… or the one who sharpens because softness might get someone killed?"},
		],
		"choices": [
			{
				"text": "Steady first. We'll drill the first exchange until it's boring.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "Dry runs until your mouth remembers the call without your fear narrating it."},
					{"speaker": "Pell Rowan", "text": "Thank you—for not making me pretend I'm already what I want to be."},
					{"speaker": "Pell Rowan", "text": "I'll take the ugly reps. If the song ever comes true, I want it earned—not rehearsed louder."},
					{"speaker": "Commander", "text": "That's the right hunger."},
					{"speaker": "Pell Rowan", "text": "Then I'll stay hungry a little longer. Better than hollow."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "Sharp. The line can't carry hesitation for you.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "I need the call clean tomorrow. Shake off the wall if you have to."},
					{"speaker": "Pell Rowan", "text": "Yes, Commander. That hurts. It also helps."},
					{"speaker": "Pell Rowan", "text": "I'll drill until my jaw aches. If I'm brittle, at least I'll be brittle in the right shape."},
					{"speaker": "Commander", "text": "Good."},
					{"speaker": "Pell Rowan", "text": "If I fail anyway—say it plain. I can't fix what I'm allowed to pretend isn't broken."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_pell_2"},
	},
	{
		"id": "dc_camp_avatar_sabine_1",
		"primary_unit": "Sabine Varr",
		"participants": ["Sabine Varr", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 17,
		"req_level": 4,
		"once_ever": true,
		"script": [
			{"speaker": "Sabine Varr", "text": "This section of the wall has a blind humor—people stand where they like the light."},
			{"speaker": "Commander", "text": "I'll move the post."},
			{"speaker": "Sabine Varr", "text": "Move the habit first. Posts are easy. Complacency isn't."},
			{"speaker": "Commander", "text": "You want drills."},
			{"speaker": "Sabine Varr", "text": "I want boredom to feel unfamiliar. Boredom is how gaps open."},
			{"speaker": "Commander", "text": "I'll rotate the watch pattern."},
			{"speaker": "Sabine Varr", "text": "Good. And Commander—don't thank me for seeing it. Thank me by not needing to say it twice."},
		],
		"effects_on_complete": {"add_avatar_relationship": 2, "advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_sabine_1"},
	},
	{
		"id": "dc_camp_avatar_oren_1",
		"primary_unit": "Oren Pike",
		"participants": ["Oren Pike", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 17,
		"req_level": 2,
		"once_ever": true,
		"script": [
			{"speaker": "Oren Pike", "text": "This map says the ford is friendly. The mud on my boots says it lies—maps are clean; consequences aren't."},
			{"speaker": "Commander", "text": "Can we cross?"},
			{"speaker": "Oren Pike", "text": "Anything crosses if you pay in time, rope, and language you wouldn't use in front of scribes."},
			{"speaker": "Commander", "text": "Give me the honest estimate."},
			{"speaker": "Oren Pike", "text": "Two hours longer than you want. Fewer broken ankles than you fear. I've watched bad measurements become someone else's problem downstream."},
			{"speaker": "Commander", "text": "I'll take it."},
			{"speaker": "Oren Pike", "text": "Good. Slow with dry powder beats fast with a story told by people who won't carry the stretcher."},
		],
		"effects_on_complete": {"add_avatar_relationship": 2, "advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_oren_1"},
	},
	{
		"id": "dc_camp_avatar_oren_2",
		"primary_unit": "Oren Pike",
		"participants": ["Oren Pike", "Commander"],
		"conversation_type": "camp_practical",
		"priority": 16,
		"req_level": 5,
		"once_ever": true,
		"branch_at": 4,
		"script": [
			{"speaker": "Oren Pike", "text": "Your night-march window assumes dry cordage and honest gravel. Weather assumes whoever drew the map never hauled a sledgewrench in the rain."},
			{"speaker": "Commander", "text": "Can we still make it?"},
			{"speaker": "Oren Pike", "text": "Anything's possible if you're buying exhausted teams and snapped stakes."},
			{"speaker": "Commander", "text": "Give me the fork."},
			{"speaker": "Oren Pike", "text": "Leave on your pretty timetable and gamble someone learns physics with their face… or take the boring hour—extra lashings, slower packs—and keep teeth intact. Which mistake do you want to own?"},
		],
		"choices": [
			{
				"text": "Boring hour. I own the delay.",
				"result": "success",
				"response": [
					{"speaker": "Commander", "text": "I'll tell the line we're buying bone and powder, not a narrative."},
					{"speaker": "Oren Pike", "text": "Good. Narratives don't hold tents."},
					{"speaker": "Oren Pike", "text": "I'll double guy lines on the weak faces and stake the mudline so some genius doesn't 'optimize' us into a ditch."},
					{"speaker": "Commander", "text": "You're in charge of the ugly details."},
					{"speaker": "Oren Pike", "text": "Ugly details are the only honest ones. I learned that before I learned your rank."},
				],
				"effects": {"add_avatar_relationship": 2},
			},
			{
				"text": "Push the window—mitigate hard; I'll absorb the risk.",
				"result": "fail",
				"response": [
					{"speaker": "Commander", "text": "We need the timing. Build safeguards but don't cost me the window."},
					{"speaker": "Oren Pike", "text": "You'll get mitigations, not miracles."},
					{"speaker": "Oren Pike", "text": "Recovery tools every fifty paces, eyes on stakes. When something gives, we'll know fast—that's the best honesty I can sell."},
					{"speaker": "Commander", "text": "Noted."},
					{"speaker": "Oren Pike", "text": "If this turns into a speech about glory, I'm walking. Glory doesn't set anchors."},
				],
				"effects": {"add_avatar_relationship": 1},
			},
		],
		"effects_on_complete": {"advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_oren_2"},
	},
	{
		"id": "dc_camp_avatar_inez_1",
		"primary_unit": "Inez",
		"participants": ["Inez", "Commander"],
		"conversation_type": "support",
		"priority": 18,
		"req_level": 5,
		"once_ever": true,
		"script": [
			{"speaker": "Inez", "text": "You walk loud when you think you're being quiet."},
			{"speaker": "Commander", "text": "Noted."},
			{"speaker": "Inez", "text": "Noted isn't a fix. A fix is shorter steps on gravel and fewer muttered plans under your breath."},
			{"speaker": "Commander", "text": "Are you coaching me or scolding me?"},
			{"speaker": "Inez", "text": "If I scold, you'll hear it on purpose."},
			{"speaker": "Commander", "text": "Why tell me at all?"},
			{"speaker": "Inez", "text": "Because the trees already know your habits. I'd rather the enemy learn them last."},
		],
		"effects_on_complete": {"add_avatar_relationship": 2, "advance_personal_arc_stage": 1, "set_arc_flag": "dc_camp_avatar_inez_1"},
	},
