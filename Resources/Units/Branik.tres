display_name = "Branik"
is_recruitable = true
recruit_dialogue = Array[String](["Stand aside, bandit. The Vanguard are hunting us, and we don't have time for you.", "I don't care about the Vanguard. Hand over the merchant's gold, or I'll smash that cart myself.", "If you smash the cart, we all starve. Help us break through this forest, and the merchant will pay you double.", "...Fine. But if that merchant shortchanges me, I'm taking his donkey."])
pre_battle_quote = Array[String](["Whoa, easy! I'm just here for the merchant's coin. We don't have to kill each other over this! Just walk away."])
