; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Legends of Aurelia : The Rift"
run/main_scene="res://Scenes/studio_intro.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SteamService="*res://Scripts/Steam/SteamService.gd"
CampaignManager="*uid://c1w4cwv2yy8pu"
ArenaManager="*uid://bqxptofjm5sjr"
SceneTransition="*uid://bni8bid8xtcdi"
SettingsMenu="*uid://bykrititb8c5c"
QTEManager="*uid://bckxtm1bf5pvh"
DragonManager="*uid://khsego8tn41h"
SilentWolf="*uid://crcb3v7qhj5vo"
RecipeDatabase="*uid://ftec3t1wl11t"
DialogueDatabase="*uid://xxc4kh1tx0q1"
ItemDatabase="*uid://borft2uumnmjj"
ScavengerManager="*uid://b3lf5jw2mhkfh"
CoopExpeditionSessionManager="*res://Scripts/Coop/CoopExpeditionSessionManager.gd"

[audio]

buses/default_bus_layout="res://default_bus_layout.tres"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/copy_all_errors/plugin.cfg", "res://addons/silent_wolf/plugin.cfg")

[gui]

theme/custom_font="uid://b8q1aga0ltd45"

